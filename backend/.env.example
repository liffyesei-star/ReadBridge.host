# ===========================
# SERVER
# ===========================
PORT=5001
NODE_ENV=development

# ===========================
# MYSQL DATABASE
# ===========================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=readbridge_db

# Wajib untuk Aiven MySQL — unduh CA cert dari Aiven Console → Service → Connect
# Tempel isi sertifikat (boleh satu baris, ganti newline dengan \n)
DB_SSL_CA=

# ===========================
# FIREBASE ADMIN SDK
# Ambil dari Firebase Console → Project Settings → Service Accounts → Generate new private key
# ===========================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com

# ===========================
# UPLOAD (opsional - untuk cover buku, foto profil)
# ===========================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ===========================
# MIDTRANS SNAP
# Gunakan key Sandbox saat development.
# ===========================
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# URL frontend yang dipakai untuk callback finish Snap
FRONTEND_URL=http://localhost:5500

# ===========================
# CORS
# ===========================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://yourdomain.com

# AI Bot Configuration
GEMINI_API_KEY=YOUR_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash
